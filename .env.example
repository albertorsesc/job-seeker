# Copy to `.env` and edit. `.env` is gitignored; this example file is not.
# Everything candidate-specific is configuration, so nothing here belongs in source.

# Absolute path to your profile Markdown file. Required.
# Keep the real file OUTSIDE this repo: it carries your name, location, skills
# and work-eligibility rules. Start from `examples/profile.example.md`.
JOB_SEEKER_PROFILE=/path/to/your-profile.md

# Where to cache fetched postings between runs. Optional.
# JOB_SEEKER_CACHE_DIR=~/.cache/job-seeker

# Comma-separated source toggles. Optional; defaults to every available source.
# JOB_SEEKER_SOURCES=himalayas,remotive,remoteok,weworkremotely
